# =============================================================================
# OEMPartsAgent Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
#
# Reference: docs/SYSTEM_CONTEXT.md Section 11

# =============================================================================
# Database
# =============================================================================
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5442
POSTGRES_DB=oemparts
POSTGRES_USER=oemparts
POSTGRES_PASSWORD=changeme_secure_password_here

# Composed from the above — used by SQLAlchemy / Alembic
DATABASE_URL=postgresql://oemparts:changeme_secure_password_here@127.0.0.1:5442/oemparts

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# eBay API (required for fetch cycles)
# =============================================================================
# Sign up at: https://developer.ebay.com/
EBAY_ENV=production
EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope

# =============================================================================
# eBay Partner Network (Phase 3+ — leave defaults for now)
# =============================================================================
EPN_CAMPAIGN_ID=
EPN_ENABLED=false

# =============================================================================
# NHTSA vPIC (free, no key required)
# =============================================================================
NHTSA_VPIC_BASE_URL=https://vpic.nhtsa.dot.gov/api

# =============================================================================
# Auth
# =============================================================================
# AUTH_BACKEND selects the auth provider:
#   basic  — Phase 1 single-user HTTP Basic (default)
#   clerk  — Phase 2 Clerk-hosted identity (requires the CLERK_* values below)
AUTH_BACKEND=basic

# --- basic backend ---
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=changeme_auth_password_here
SESSION_SECRET_KEY=changeme_generate_a_32_byte_hex_string

# --- clerk backend (only needed when AUTH_BACKEND=clerk) ---
# Create an application at https://dashboard.clerk.com and copy its API keys.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Comma-separated list of origins allowed to use the session (CSRF protection).
# Include your local dev origin and production domain, e.g.:
#   CLERK_AUTHORIZED_PARTIES=http://localhost:8000,https://oempartsagent.com
CLERK_AUTHORIZED_PARTIES=

# =============================================================================
# Fetching Behavior
# =============================================================================
FETCH_DEFAULT_TTL_MINUTES=240
FETCH_MAX_LISTINGS_PER_QUERY=50
FETCH_API_RATE_LIMIT_PER_MIN=30

# =============================================================================
# Alerts (Phase 3 — disabled for now)
# =============================================================================
ALERTS_ENABLED=false
# AWS_SES_REGION=us-east-1
# AWS_SES_FROM_EMAIL=alerts@oempartsagent.com

# =============================================================================
# Cleanup
# =============================================================================
LISTING_INACTIVE_AFTER_MISSING_CYCLES=3
LISTING_ARCHIVE_AFTER_DAYS=180
